{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "rootDir": "./",

    /* Preact Config */
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "react": ["./node_modules/preact/compat/"],
      "react-dom": ["./node_modules/preact/compat/"],

      /* In sync with vite.config.ts */
      "@app/*": ["./src/app/*"],
      "@page/*": ["./src/pages/*"],
      "@comp/*": ["./src/components/*"],
      "@fwk/*": ["./src/_framework/*"],
      "@res/*": ["./res/*"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist"]
}
