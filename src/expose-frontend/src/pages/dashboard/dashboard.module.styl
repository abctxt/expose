.dashboard
  padding 16px
  box-sizing border-box
  flex(v no-wrap left)
  min-height 0

.heading
  margin 0 0 12px
  font-size 1.125rem
  font-weight 600
  color var(--sapTextColor, #1d2d3e)

.chartShell
  flex(none)
  width 100%
  min-width 280px
  min-height 400px

.chart
  flex(none)
  width 100%
