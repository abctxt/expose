.dashboard
  padding 16px
  height 100%
  box-sizing border-box
  flex(v no-wrap)
  gap 12px

.header
  flex(h between i-middle no-wrap)
  h2
    margin 0

.meta
  opacity 0.75
  font-size 0.9rem

.message
  margin 0
  padding 8px 0

.error
  margin 0
  padding 8px 0
  color #b50f2f

.tableWrap
  max-height 60dvh
  overflow auto
  border 1px #d0d0d0 solid
  background #ffffff

.table
  width 100%
  border-collapse collapse
  th, td
    padding 10px 12px
    border-bottom 1px #e8e8e8 solid
    text-align left
  th
    position sticky
    top 0
    background #f5f5f5
    z-index 1

.sortHeader
  cursor pointer
  user-select none

.controlsRow
  flex(h between i-middle no-wrap)

.priceSettings
  flex(h left i-middle no-wrap)
  gap 8px
  label
    font-size 0.92rem
  select
    min-width 64px

.currentDate
  color #666666
