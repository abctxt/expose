{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "start": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5777",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "start:yfinance": {
      "commandName": "Executable",
      "executablePath": "$(SolutionDir)src/expose-yfinance/.venv/bin/python",
      "workingDirectory": "$(SolutionDir)src/expose-yfinance",
      "commandLineArgs": "-m expose_yfinance.main"
    }
  }
}
